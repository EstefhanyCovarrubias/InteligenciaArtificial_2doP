# Búsquedas AO*
# Grafo AND/OR. Definimos si los hijos de un nodo son opciones (OR) o requisitos (AND)
grafo_and_or = {
    'A': {'tipo': 'OR',  'hijos': ['B', 'C']},   # A puede resolverse con B o C
    'B': {'tipo': 'AND', 'hijos': ['D', 'E']},   # B requiere resolver D y E (ambos obligatorios)
    'C': {'tipo': 'OR',  'hijos': ['F']},        # C se resuelve con F
    # Nodos terminales (sub-tareas más pequeñas ya resueltas)
    'D': {'tipo': 'OR', 'hijos': []},            # D no tiene hijos, es hoja
    'E': {'tipo': 'OR', 'hijos': []},            # E no tiene hijos, es hoja
    'F': {'tipo': 'OR', 'hijos': []}             # F no tiene hijos, es hoja
}

# Heurística: costo estimado de resolver cada sub-tarea individualmente
# Valores más bajos indican tareas más fáciles/baratas
h_costos = {
    'A': 10, 'B': 8, 'C': 5, 
    'D': 2,  'E': 3, 'F': 6
}

def resolver_ao_estrella(grafo, h, nodo):
    # Obtenemos la información del nodo (tipo y lista de hijos)
    info_nodo = grafo.get(nodo, {'tipo': 'OR', 'hijos': []})
    
    # Caso base: si el nodo es terminal (no tiene hijos), devolvemos su costo heurístico
    if not info_nodo['hijos']:
        print(f"  [Hoja] Tarea '{nodo}' completada. Costo: {h[nodo]}")
        return h[nodo]
        
    # Si el nodo no es terminal, evaluamos cómo resolverlo
    print(f"Evaluando cómo resolver '{nodo}' (Tipo: {info_nodo['tipo']})")
    costos_hijos = []
    
    # Llamamos recursivamente a la función para cada hijo
    for hijo in info_nodo['hijos']:
        costos_hijos.append(resolver_ao_estrella(grafo, h, hijo))
        
    # Si el nodo es de tipo AND, necesitamos resolver TODOS sus hijos
    if info_nodo['tipo'] == 'AND':
        # Sumamos los costos de los hijos +1 por el esfuerzo de combinarlos
        costo_total = sum(costos_hijos) + 1
        print(f"  -> Para resolver '{nodo}' (AND), se requiere resolver todos sus hijos. Costo calculado: {costo_total}")
        return costo_total
        
    # Si el nodo es de tipo OR, basta con elegir la opción más barata
    elif info_nodo['tipo'] == 'OR':
        # Tomamos el mínimo de los costos +1 por el esfuerzo de elegir
        costo_total = min(costos_hijos) + 1
        print(f"  -> Para resolver '{nodo}' (OR), tomamos la mejor opción. Costo calculado: {costo_total}")
        return costo_total

# Ejecución del algoritmo AO*
print("--- Iniciando Resolución de Problema con AO* ---")
costo_final = resolver_ao_estrella(grafo_and_or, h_costos, 'A')
print(f"\nEl costo óptimo total para resolver el problema raíz 'A' es: {costo_final}")
